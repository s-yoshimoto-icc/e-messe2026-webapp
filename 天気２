<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>e-messe Digital Weather Forecast</title>
    <link rel="stylesheet" href="style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Noto+Sans+JP:wght@400;500;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <div id="app" class="app-container">
        <!-- Header -->
        <header class="header">
            <div class="header-top">
                <button id="p2-home-btn" class="home-btn" title="ホームへ戻る">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </button>
                <div class="step-indicator">
                    <span id="step-name">デジタル天気予報</span>
                    <span id="question-count">設問 1 / 8</span>
                </div>
            </div>
            <div class="progress-bar-container">
                <div id="progress" class="progress-bar" style="width: 0%;"></div>
            </div>
        </header>

        <main class="main-content">
            <div id="content-area">
                <!-- Welcome/Branch Screen -->
                <div id="branch-screen" class="screen welcome-container">
                    <span class="subtitle">Digital Transformation</span>
                    <h1 class="title">デジタル天気予報</h1>
                    <p class="description">
                        現在のライフスタイルから、<br>
                        あなたに最適なデジタル活用度を診断します。
                    </p>
                    <div class="options-stack">
                        <button id="btn-student" class="btn btn-primary">学生の方はこちら</button>
                        <button id="btn-worker" class="btn btn-accent">社会人の方はこちら</button>
                    </div>
                </div>

                <!-- Transition/Ready Screen (P2 Welcome) -->
                <div id="transition-screen" class="screen welcome-container hidden">
                    <span class="subtitle">Weather Forecast</span>
                    <h1 class="title">デジタル天気予報</h1>
                    <p id="transition-msg" class="description"></p>
                    <button id="p2-start-btn" class="btn btn-accent btn-large">診断を開始する</button>
                    <div style="margin-top: 20px; font-size: 0.8rem; color: #94A3B8;">所要時間：約2分</div>
                </div>

                <!-- Questions Area -->
                <div id="question-screen" class="screen hidden">
                    <h2 id="question-text" class="question-title"></h2>
                    <div id="options-container" class="options-stack">
                        <!-- Options generated by JS -->
                    </div>
                    <!-- Back Button -->
                    <div id="p2-back-btn-container" class="bottom-nav hidden">
                        <button id="p2-back-btn" class="text-link-btn" style="margin-bottom: 10px;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px; vertical-align: text-bottom;"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                            1つ前の設問に戻る
                        </button>
                    </div>
                    <!-- Small bottom home button during diagnosis -->
                    <div class="bottom-nav" style="margin-top: 10px;">
                        <button id="p2-bottom-home-btn" class="text-link-btn">デジタル天気予報のホームに戻る</button>
                    </div>
                </div>

                <!-- Result Screen -->
                <div id="p2-result-screen" class="screen hidden">
                    <div class="result-card fade-in">
                        <span id="p2-icon" class="result-icon">☀️</span>
                        <div class="result-label">Diagnostic Result</div>
                        <h3 id="p2-title" class="result-main-title"></h3>
                        <div id="p2-status" class="weather-status-badge"></div>
                        <div id="p2-description" class="result-text"></div>
                        
                        <div class="recommend-container">
                            <div class="recommend-list">
                                <h4>おすすめ製品デモ</h4>
                                <div id="p2-recommend" class="recommend-item"></div>
                            </div>
                        </div>

                        <div class="result-actions">
                            <button id="p2-back-p1-btn" class="btn btn-accent btn-compact">性格診断に戻る</button>
                            <button id="p2-retry-p2-btn" class="btn btn-outline btn-compact">デジタル天気予報のホームに戻る</button>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <footer class="footer-branding">
            e-messe 2026 | Powered by e-bookAC
        </footer>
    </div>
    <script src="p2.js"></script>
</body>
</html>
